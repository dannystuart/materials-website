# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Source video masters and Figma exports (re-encoded outputs live in public/videos)
assets-source/

# Visual-reviewer artifacts (Playwright MCP logs + ad-hoc screenshot dumps)
.playwright-mcp/
desktop-*.png
mobile-*.png
# Root-level scratch screenshots from build/review cycles — keep out of git
/cta-*.png
/pitch-*.png
/hero-*.png
/cycle-*.png
/cycle-mid-*.png
/smoother-*.png
/section-*.png
